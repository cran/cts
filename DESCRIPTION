Package: cts
Title: Continuous Time Autoregressive Models
Version: 1.0-26
Date: 2026-05-14
Authors@R: c(
    person("Granville", "Tunnicliffe-Wilson", role = "aut"),
    person("Zhu", "Wang", email = "zwang145@uthsc.edu", role = c("aut", "cre")),
